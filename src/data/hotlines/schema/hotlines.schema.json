{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Maasin Hotlines",
  "description": "Schema for Maasin hotlines organized by category",
  "type": "object",
  "required": [
    "emergencyHotlines",
    "disasterHotlines",
    "securityHotlines",
    "transportHotlines",
    "weatherHotlines",
    "utilityHotlines",
    "socialServicesHotlines",
    "criticalHotlines"
  ],
  "properties": {
    "emergencyHotlines": {
      "type": "array",
      "items": { "$ref": "#/definitions/hotline" }
    },
    "disasterHotlines": {
      "type": "array",
      "items": { "$ref": "#/definitions/hotline" }
    },
    "securityHotlines": {
      "type": "array",
      "items": { "$ref": "#/definitions/hotline" }
    },
    "transportHotlines": {
      "type": "array",
      "items": { "$ref": "#/definitions/hotline" }
    },
    "weatherHotlines": {
      "type": "array",
      "items": { "$ref": "#/definitions/hotline" }
    },
    "utilityHotlines": {
      "type": "array",
      "items": { "$ref": "#/definitions/hotline" }
    },
    "socialServicesHotlines": {
      "type": "array",
      "items": { "$ref": "#/definitions/hotline" }
    },
    "criticalHotlines": {
      "type": "array",
      "items": { "$ref": "#/definitions/hotline" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "hotline": {
      "type": "object",
      "required": ["name", "category", "numbers", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "Emergency",
            "Disaster",
            "Security",
            "Transport",
            "Weather",
            "Utility",
            "Social Services"
          ]
        },
        "numbers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
